{
  "name": "cinematic-ar-restaurant-menu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "cf:prune-assets": "node scripts/prune-cloudflare-assets.mjs",
    "preview": "opennextjs-cloudflare build && npm run cf:prune-assets && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && npm run cf:prune-assets && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && npm run cf:prune-assets && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "framer-motion": "^12.6.2",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.174.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.174.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.8.2",
    "wrangler": "^4.80.0"
  }
}
